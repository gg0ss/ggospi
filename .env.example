# ── Telegram ────────────────────────────────────────
TELEGRAM_BOT_TOKEN=""
TELEGRAM_ALLOWED_USER_IDS=""          # IDs separados por coma. Vacío = todos.

# ── GGOS: DeepSeek V3 ───────────────────────────────
DEEPSEEK_API_KEY=""
DEEPSEEK_API_URL="https://api.deepseek.com/v1"
DEEPSEEK_MODEL="deepseek-chat"
DEEPSEEK_TIMEOUT_MS=15000             # 15s timeout antes de usar fallback

# ── Ollama ───────────────────────────────────────────
OLLAMA_URL="http://localhost:11434"
OLLAMA_MODEL_KALI="kali-ggos"         # Modelo creado desde Modelfile optimizado
OLLAMA_BASE_MODEL="dolphin3"          # Modelo base a descargar si no existe
OLLAMA_FALLBACK_MODEL="llama3.2:3b"   # Fallback para GGOS si DeepSeek falla

# ── Base de datos ────────────────────────────────────
DB_PATH="./memory.db"

# ── Límites ──────────────────────────────────────────
CONFIRMATION_TIMEOUT_SECONDS=60
MAX_FILE_SIZE_MB=50
MAX_AGENT_ITERATIONS=3
MAX_HISTORY_MESSAGES=20

# ── Directorios ──────────────────────────────────────
TMP_DIR="./tmp"
MODELFILES_DIR="./modelfiles"
